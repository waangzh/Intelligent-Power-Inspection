map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

upstream power_inspection_backend {
    server 127.0.0.1:8080;
}

upstream robot_bridge {
    server 127.0.0.1:8001;
}

server {
    listen 443 ssl http2;
    server_name waang.top;
    root /opt/power-inspection/current/frontend/dist;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/waang.top/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/waang.top/privkey.pem;

    location /api/ {
        proxy_pass http://power_inspection_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /ws {
        proxy_pass http://power_inspection_backend/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
    }

    location /ws/ {
        proxy_pass http://power_inspection_backend/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
    }

    location /bridge/ { return 404; }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 8000 ssl;
    server_name waang.top;

    ssl_certificate /etc/letsencrypt/live/waang.top/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/waang.top/privkey.pem;

    location /robot-api/ {
        proxy_pass http://robot_bridge/robot-api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    location / { return 404; }
}
