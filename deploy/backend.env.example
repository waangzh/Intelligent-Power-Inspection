# Install as /etc/power-inspection/backend.env with owner root:powerinspection and mode 0640.
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=8080
DB_URL=jdbc:mysql://127.0.0.1:3306/power_inspection?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=power_inspection
DB_PASSWORD=replace-me
JWT_SECRET=replace-with-at-least-32-random-bytes
CORS_ALLOWED_ORIGINS=https://waang.top
APP_ROBOT_MODE=bridge
ROBOT_BRIDGE_BASE_URL=http://127.0.0.1:8001
ROBOT_BRIDGE_ADMIN_TOKEN=replace-me
ROBOT_BRIDGE_PLATFORM_TOKEN=replace-me
APP_ROBOT_BRIDGE_ID_ROBOT_001=robot-001
APP_ROBOT_INSPECTION_MAX_IMAGE_BYTES=20971520
APP_ROBOT_INSPECTION_MAX_IMAGE_PIXELS=40000000
