<view class="detection-config">
  <view class="det-row det-head">
    <text class="col-name">检测项</text>
    <text class="col-en">启用</text>
    <text class="col-th">阈值</text>
  </view>
  <view class="det-row" wx:for="{{rows}}" wx:key="type">
    <text class="col-name">{{item.label}}</text>
    <switch class="col-en" checked="{{item.enabled}}" data-idx="{{index}}" bindchange="onToggle" color="#1a5fb4" />
    <slider class="col-th" min="50" max="99" value="{{item.thresholdPct}}" show-value data-idx="{{index}}" bindchange="onThreshold" activeColor="#1a5fb4" />
    <input wx:if="{{item.needsPrompt}}" class="prompt-input" placeholder="LocateAnything 提示词" value="{{item.prompt}}" data-idx="{{index}}" bindinput="onPrompt" />
  </view>
</view>
