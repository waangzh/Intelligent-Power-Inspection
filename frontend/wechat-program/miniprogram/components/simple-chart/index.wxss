.chart {
  padding: 12rpx 0 8rpx;
}

.chart-bars,
.line-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 220rpx;
  gap: 16rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
  min-width: 0;
}

.bar,
.line-bar {
  width: 72%;
  max-width: 56rpx;
  min-height: 8rpx;
  background: var(--pi-primary);
  border-radius: 8rpx 8rpx 0 0;
}

.line-bar {
  background: var(--pi-warning);
  opacity: 0.85;
}

.bar-label,
.line-label {
  font-size: 22rpx;
  color: var(--pi-muted-light);
  margin-top: 12rpx;
}

.bar-val {
  font-size: 22rpx;
  color: var(--pi-text);
  margin-top: 4rpx;
}

.line-labels {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0 12rpx;
}

.line-label {
  flex: 1;
  text-align: center;
}

.gauge {
  text-align: center;
  padding: 24rpx 16rpx 8rpx;
}

.gauge-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 14rpx solid var(--pi-primary);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gauge-val {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--pi-primary);
}

.gauge-title {
  font-size: 26rpx;
  color: var(--pi-muted);
  margin-top: 16rpx;
  display: block;
}
