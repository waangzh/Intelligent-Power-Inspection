.ros-map-wrap {
  width: 100%;
  overflow: hidden;
  border-radius: 16rpx;
  background:
    linear-gradient(45deg, #e8edf2 25%, transparent 25%),
    linear-gradient(-45deg, #e8edf2 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #e8edf2 75%),
    linear-gradient(-45deg, transparent 75%, #e8edf2 75%);
  background-size: 24rpx 24rpx;
  background-position: 0 0, 0 12rpx, 12rpx -12rpx, -12rpx 0;
}

.ros-canvas {
  display: block;
  width: 100%;
  height: 100%;
}
