.toolbar { display: flex; justify-content: flex-end; }
.info-row { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 16rpx; }
.info-card { flex: 1; min-width: 45%; }
.info-text { font-size: 26rpx; color: #606266; line-height: 1.7; margin-bottom: 12rpx; }
.layer-row { display: flex; gap: 12rpx; padding: 10rpx 0; border-bottom: 1rpx solid #f0f2f5; font-size: 26rpx; }
.layer-label { color: #1a5fb4; font-weight: 600; width: 120rpx; flex-shrink: 0; }
.tag-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin: 8rpx 0; }
.prompt-row { margin-top: 8rpx; }
.prompt { font-size: 22rpx; color: #909399; margin-right: 12rpx; }
.form-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.form-label { width: 100rpx; color: #6b7c93; }
.form-row input { flex: 1; border: 1rpx solid #e4e7ed; border-radius: 8rpx; padding: 12rpx; }
.picker-val { color: #1a5fb4; }
.tpl-name { font-weight: 600; }
.link { font-size: 26rpx; }
.danger { color: #f56c6c; }
