.bigscreen { min-height: 100vh; background: #0a1628; color: #e8f0fe; padding: 24rpx; }
.bs-header { text-align: center; margin-bottom: 24rpx; }
.bs-actions { display: flex; justify-content: center; gap: 24rpx; margin-top: 12rpx; }
.bs-btn { color: #64b5ff; font-size: 24rpx; }
.bs-title { display: block; font-size: 36rpx; font-weight: 700; color: #4da3ff; }
.bs-clock { font-size: 24rpx; color: #6b8cb8; margin-top: 8rpx; }
.kpi-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.kpi { flex: 1; min-width: 40%; text-align: center; background: rgba(26, 95, 180, 0.15); border: 1rpx solid #1a5fb4; border-radius: 12rpx; padding: 16rpx; }
.kpi-val { display: block; font-size: 40rpx; font-weight: 700; }
.kpi-lbl { font-size: 22rpx; color: #8aa8cc; }
.bs-panel { background: rgba(13, 33, 55, 0.85); border: 1rpx solid #1a3a5c; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; }
.bs-panel-title { font-size: 26rpx; color: #4da3ff; margin-bottom: 16rpx; font-weight: 600; }
.chart-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chart-panel { flex: 1; min-width: 45%; }
.ticker-wrap { overflow: hidden; white-space: nowrap; }
.ticker { display: inline-block; padding-left: 100%; animation: ticker 30s linear infinite; font-size: 24rpx; color: #f56c6c; }
@keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-100%); } }
.wo-stats { display: flex; gap: 16rpx; }
.wo-stat { flex: 1; text-align: center; }
.wo-val { display: block; font-size: 36rpx; font-weight: 700; color: #ffd700; }
.wo-lbl { font-size: 22rpx; color: #8aa8cc; }
.robot-row, .task-row { display: flex; align-items: center; gap: 12rpx; padding: 10rpx 0; border-bottom: 1rpx solid #1a3a5c; font-size: 24rpx; }
.bs-badge { color: #67c23a; }
.bs-status { color: #8aa8cc; font-size: 22rpx; }
.task-name { flex: 1; }
.bs-empty { color: #6b8cb8; text-align: center; padding: 24rpx; font-size: 24rpx; }
