.forbidden-page { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; padding: 48rpx; }
.code { font-size: 120rpx; font-weight: 700; color: var(--pi-primary); opacity: 0.3; }
.title { font-size: 40rpx; font-weight: 700; margin: 16rpx 0; color: var(--pi-text); }
.desc { color: var(--pi-muted-light); text-align: center; margin-bottom: 48rpx; }
.actions { display: flex; gap: 24rpx; }
