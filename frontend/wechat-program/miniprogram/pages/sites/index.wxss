.toolbar { margin-bottom: 16rpx; }
.site-item { margin-bottom: 16rpx; }
.site-item.sel { border: 2rpx solid #1a5fb4; }
.site-name { font-weight: 600; }
.site-actions { margin-top: 12rpx; display: flex; gap: 24rpx; }
.area-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f0f2f5; }
.form-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.form-label { width: 140rpx; color: #6b7c93; font-size: 26rpx; }
.form-row input { flex: 1; border: 1rpx solid #e4e9f0; border-radius: 8rpx; padding: 12rpx; }
.form-actions { display: flex; gap: 16rpx; justify-content: flex-end; }
.link.danger { color: #f56c6c; }
