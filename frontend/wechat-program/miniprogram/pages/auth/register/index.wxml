<view class="auth-page">
  <view class="auth-card">
    <view class="brand">创建账号</view>
    <text class="subtitle">默认角色为观察员；需手机号短信验证</text>
    <view class="form-item">
      <input class="input" placeholder="用户名（4～20 位字母数字下划线）" value="{{form.username}}" data-k="username" bindinput="onInput" />
    </view>
    <view class="form-item">
      <input class="input" placeholder="姓名" value="{{form.displayName}}" data-k="displayName" bindinput="onInput" />
    </view>
    <view class="form-item">
      <input class="input" type="number" maxlength="11" placeholder="手机号" value="{{form.phone}}" data-k="phone" bindinput="onInput" />
    </view>
    <view class="form-item sms-row">
      <input class="input sms-input" type="number" maxlength="8" placeholder="短信验证码" value="{{form.smsCode}}" data-k="smsCode" bindinput="onInput" />
      <view
        class="sms-btn {{smsSending || smsCooldown > 0 ? 'sms-btn--disabled' : ''}}"
        bindtap="handleSendSms"
      >
        <text class="sms-btn-text">{{smsBtnLabel}}</text>
      </view>
    </view>
    <view class="form-item">
      <input class="input" password placeholder="密码（至少 8 位，含字母和数字）" value="{{form.password}}" data-k="password" bindinput="onInput" />
    </view>
    <view class="form-item">
      <input class="input" password placeholder="确认密码" value="{{form.confirmPassword}}" data-k="confirmPassword" bindinput="onInput" />
    </view>
    <label class="remember">
      <checkbox checked="{{form.agreed}}" bindtap="toggleAgreed" color="#1768f2" /> 我已阅读并同意服务条款
    </label>
    <button class="submit btn-primary" plain hover-class="none" loading="{{loading}}" disabled="{{loading}}" bindtap="handleRegister">注 册</button>
    <view class="footer">已有账号？<text class="link" bindtap="goLogin">去登录</text></view>
  </view>
</view>
