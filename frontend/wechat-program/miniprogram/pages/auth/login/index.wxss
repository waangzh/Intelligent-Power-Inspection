@import '../../../config/theme.wxss';

.auth-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #061018 0%, #0c2240 40%, #143560 70%, #0a1a30 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.session-check {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.session-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #64b5ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.session-text {
  color: rgba(255, 255, 255, 0.82);
  font-size: 28rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.auth-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  padding: 48rpx 40rpx 56rpx;
  box-shadow: 0 16rpx 48rpx rgba(6, 16, 24, 0.28);
}

.brand {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--pi-sidebar);
  text-align: center;
}

.subtitle {
  display: block;
  text-align: center;
  color: var(--pi-muted);
  font-size: 26rpx;
  margin: 16rpx 0 40rpx;
}

.form-item { margin-bottom: 24rpx; }

.input {
  border: 1rpx solid var(--pi-border);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.remember {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--pi-muted);
  margin-bottom: 32rpx;
}

.submit {
  margin-bottom: 40rpx;
  border-radius: 16rpx;
}

.footer-links {
  padding-top: 8rpx;
}

.footer-item {
  text-align: center;
  font-size: 26rpx;
  color: var(--pi-muted);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.footer-item:last-child {
  margin-bottom: 0;
}

.link { color: var(--pi-primary); }
