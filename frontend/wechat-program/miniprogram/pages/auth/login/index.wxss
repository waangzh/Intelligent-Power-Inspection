@import '../../../config/theme.wxss';

.auth-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #061018 0%, #0c2240 40%, #143560 70%, #0a1a30 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.auth-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(6, 16, 24, 0.28);
}

.brand {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--pi-sidebar);
  text-align: center;
}

.subtitle {
  display: block;
  text-align: center;
  color: var(--pi-muted);
  font-size: 26rpx;
  margin: 16rpx 0 40rpx;
}

.form-item { margin-bottom: 24rpx; }

.input {
  border: 1rpx solid var(--pi-border);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.remember {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--pi-muted);
  margin-bottom: 32rpx;
}

.submit { margin-bottom: 24rpx; border-radius: 16rpx; }

.footer {
  text-align: center;
  font-size: 26rpx;
  color: var(--pi-muted);
}

.link { color: var(--pi-primary); }

.divider {
  text-align: center;
  color: var(--pi-muted-light);
  font-size: 24rpx;
  margin: 32rpx 0 16rpx;
}

.demo-tags {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  flex-wrap: wrap;
}

.demo-tag {
  background: var(--pi-primary-soft);
  color: var(--pi-primary);
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}
