.auth-page { min-height: 100vh; background: linear-gradient(160deg, #0d2137 0%, #1a5fb4 100%); display: flex; align-items: center; justify-content: center; padding: 40rpx; }
.auth-card { width: 100%; background: #fff; border-radius: 24rpx; padding: 48rpx 40rpx; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15); }
.brand { font-size: 40rpx; font-weight: 700; color: #0d2137; text-align: center; }
.subtitle { display: block; text-align: center; color: #6b7c93; font-size: 26rpx; margin: 16rpx 0 40rpx; }
.form-item { margin-bottom: 24rpx; }
.input { border: 1rpx solid #e4e9f0; border-radius: 12rpx; padding: 24rpx; font-size: 28rpx; }
.remember { display: flex; align-items: center; font-size: 26rpx; color: #6b7c93; margin-bottom: 32rpx; }
.submit { margin-bottom: 24rpx; border-radius: 12rpx; }
.footer { text-align: center; font-size: 26rpx; color: #6b7c93; }
.link { color: #1a5fb4; }
.divider { text-align: center; color: #c0c4cc; font-size: 24rpx; margin: 32rpx 0 16rpx; }
.demo-tags { display: flex; gap: 16rpx; justify-content: center; flex-wrap: wrap; }
.demo-tag { background: #f0f4f8; color: #1a5fb4; padding: 12rpx 24rpx; border-radius: 8rpx; font-size: 24rpx; }
