<view class="auth-page">
  <view class="session-check" wx:if="{{checkingSession && !loading}}">
    <view class="session-spinner" />
    <text class="session-text">正在进入系统…</text>
  </view>

  <view class="auth-card" wx:if="{{!checkingSession || loading}}">
    <view class="brand">⚡ 电力智能巡检</view>
    <text class="subtitle">欢迎回来，请登录您的账号</text>

    <view class="form-item">
      <input class="input" placeholder="用户名" value="{{username}}" bindinput="onUser" />
    </view>
    <view class="form-item">
      <input class="input" password placeholder="密码" value="{{password}}" bindinput="onPass" />
    </view>
    <label class="remember">
      <checkbox checked="{{remember}}" bindtap="toggleRemember" color="#1768f2" /> 记住我（7 天）
    </label>

    <button class="submit btn-primary" loading="{{loading}}" bindtap="handleLogin">登 录</button>

    <view class="footer-links">
      <view class="footer-item">
        <text class="link" bindtap="goForgotPassword">忘记密码？</text>
      </view>
      <view class="footer-item">
        还没有账号？<text class="link" bindtap="goRegister">立即注册</text>
      </view>
    </view>
  </view>
</view>
