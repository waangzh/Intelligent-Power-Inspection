<view class="auth-page">
  <view class="auth-card">
    <view class="brand">⚡ 电力智能巡检</view>
    <text class="subtitle">欢迎回来，请登录您的账号</text>

    <view class="form-item">
      <input class="input" placeholder="用户名" value="{{username}}" bindinput="onUser" />
    </view>
    <view class="form-item">
      <input class="input" password placeholder="密码" value="{{password}}" bindinput="onPass" />
    </view>
    <label class="remember">
      <checkbox checked="{{remember}}" bindtap="toggleRemember" color="#1a5fb4" /> 记住我（7 天）
    </label>

    <button class="submit btn-primary" loading="{{loading}}" bindtap="handleLogin">登 录</button>

    <view class="footer">
      还没有账号？<text class="link" bindtap="goRegister">立即注册</text>
    </view>

    <view class="divider">演示账号</view>
    <view class="demo-tags">
      <text class="demo-tag" bindtap="fillDemo" data-u="admin" data-p="Admin@123">管理员</text>
      <text class="demo-tag" bindtap="fillDemo" data-u="dispatcher" data-p="Disp@123">调度员</text>
      <text class="demo-tag" bindtap="fillDemo" data-u="viewer" data-p="View@123">观察员</text>
    </view>
  </view>
</view>
