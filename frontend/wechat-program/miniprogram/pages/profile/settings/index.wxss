.setting-row { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f0f2f5; }
.setting-row:last-child { border-bottom: none; }
.group-title { font-size: 28rpx; font-weight: 600; margin-bottom: 8rpx; color: #1a2b3c; }
.group-desc { display: block; font-size: 22rpx; color: #909399; margin-bottom: 16rpx; }
.hint { display: block; font-size: 22rpx; color: #909399; margin-top: 4rpx; }
.picker-val { color: #1a5fb4; font-size: 26rpx; }
.policy-row { padding: 20rpx 0; border-bottom: 1rpx solid #eef2f6; }
.policy-row:last-child { border-bottom: none; padding-bottom: 0; }
.policy-head { display: flex; align-items: center; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.policy-hint { font-size: 22rpx; color: #909399; }
.policy-modes { display: flex; gap: 12rpx; }
.mode-chip { flex: 1; text-align: center; padding: 14rpx 20rpx; background: #f0f4f8; border-radius: 8rpx; font-size: 24rpx; color: #606266; }
.mode-chip.on { background: #1a5fb4; color: #fff; }
