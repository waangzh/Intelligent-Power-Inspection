<view class="container">
  <page-header title="偏好设置" description="自定义通知与界面偏好" />

  <view class="card settings-card">
    <view class="group-title">消息通知</view>
    <view class="setting-row">
      <view class="setting-main">
        <text class="setting-label">告警通知</text>
        <text class="hint">有新告警时提醒</text>
      </view>
      <switch checked="{{prefs.notifyAlarm}}" data-key="notifyAlarm" bindchange="onSwitch" color="#1768f2" />
    </view>
    <view class="setting-row">
      <view class="setting-main">
        <text class="setting-label">任务通知</text>
        <text class="hint">任务状态变更时提醒</text>
      </view>
      <switch checked="{{prefs.notifyTask}}" data-key="notifyTask" bindchange="onSwitch" color="#1768f2" />
    </view>
    <view class="setting-row">
      <view class="setting-main">
        <text class="setting-label">系统通知</text>
        <text class="hint">系统公告与维护提醒</text>
      </view>
      <switch checked="{{prefs.notifySystem}}" data-key="notifySystem" bindchange="onSwitch" color="#1768f2" />
    </view>
  </view>

  <view class="card settings-card">
    <view class="group-title">界面偏好</view>
    <view class="setting-row setting-row-picker">
      <view class="setting-main">
        <text class="setting-label">默认站点</text>
        <text class="hint">进入总览时默认站点</text>
      </view>
      <picker mode="selector" range="{{sites}}" range-key="name" bindchange="onSiteChange">
        <view class="picker-val">{{siteLabel}} ▾</view>
      </picker>
    </view>
    <view class="setting-row setting-row-action" wx:if="{{prefs.defaultSiteId}}">
      <text class="link" bindtap="clearSite">清除默认站点</text>
    </view>
  </view>

  <view class="card settings-card" wx:if="{{canManagePolicy}}">
    <view class="group-title">告警转工单策略</view>
    <text class="group-desc">按告警级别配置自动或人工转工单，保存后立即生效</text>
    <view class="policy-row" wx:for="{{policyRows}}" wx:key="severity">
      <view class="policy-head">
        <text class="tag tag-{{item.sevType}}">{{item.label}}</text>
        <text class="policy-hint">{{item.hint}}</text>
      </view>
      <view class="policy-modes">
        <text
          class="mode-chip {{item.mode==='AUTO'?'on':''}}"
          bindtap="setPolicyMode"
          data-severity="{{item.severity}}"
          data-mode="AUTO"
        >自动转工单</text>
        <text
          class="mode-chip {{item.mode==='MANUAL'?'on':''}}"
          bindtap="setPolicyMode"
          data-severity="{{item.severity}}"
          data-mode="MANUAL"
        >人工转工单</text>
      </view>
    </view>
  </view>
</view>
