<view class="container">
  <page-header title="我的记录" description="账号操作活动日志" />

  <view class="card act-item" wx:for="{{activities}}" wx:key="id">
    <view class="flex-between">
      <text class="tag tag-primary">{{item.typeLabel}}</text>
      <text class="muted">{{item.time}}</text>
    </view>
    <view class="act-msg">{{item.message}}</view>
  </view>
  <view wx:if="{{!activities.length}}" class="empty-hint">暂无活动记录</view>
</view>
