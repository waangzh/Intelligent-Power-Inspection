.avatar-card { display: flex; flex-direction: column; align-items: center; gap: 24rpx; padding: 48rpx; }
.avatar-preview-wrap { width: 200rpx; height: 200rpx; border-radius: 50%; overflow: hidden; }
.avatar-preview { width: 200rpx; height: 200rpx; border-radius: 50%; }
.hint { font-size: 22rpx; color: #909399; }
.avatar-actions { display: flex; gap: 16rpx; flex-wrap: wrap; justify-content: center; }
.nav-preview { display: flex; align-items: center; gap: 16rpx; padding: 16rpx; background: #0d2137; border-radius: 12rpx; }
.nav-meta { flex: 1; }
.nav-name { display: block; color: #fff; font-size: 28rpx; }
.nav-bio { color: #8aa8cc !important; font-size: 22rpx; }
