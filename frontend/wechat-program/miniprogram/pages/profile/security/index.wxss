.account-card .card-title,
.password-card .card-title {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--pi-border-soft);
}

.info-row:last-child {
  border-bottom: none;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-of-type {
  margin-bottom: 12rpx;
}

.form-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--pi-text);
  line-height: 1.4;
}

.form-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--pi-border);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--pi-text);
  background: #fff;
}

.form-placeholder {
  color: var(--pi-muted-light);
  font-size: 28rpx;
}

.form-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.form-actions button {
  width: 100%;
  margin: 0;
  border-radius: 16rpx;
}
