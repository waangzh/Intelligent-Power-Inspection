<view class="container" wx:if="{{user}}">
  <view class="profile-header card">
    <user-avatar displayName="{{user.displayName}}" avatarUrl="{{editing ? avatarPreview : user.avatarUrl}}" seed="{{user.id}}" size="120" />
    <view class="profile-meta">
      <text class="profile-name">{{user.displayName}}</text>
      <text class="muted">@{{user.username}} · {{roleLabel}}</text>
      <text class="muted bio-preview" wx:if="{{user.bio}}">{{user.bio}}</text>
    </view>
    <button size="mini" class="btn-plain" bindtap="toggleEdit">{{editing ? '取消' : '编辑资料'}}</button>
  </view>

  <view class="card" wx:if="{{!editing}}">
    <view class="info-row"><text class="muted">姓名</text><text>{{user.displayName}}</text></view>
    <view class="info-row"><text class="muted">用户名</text><text>{{user.username}}</text></view>
    <view class="info-row"><text class="muted">手机</text><text>{{user.phone || '未填写'}}</text></view>
    <view class="info-row"><text class="muted">个性签名</text><text>{{user.bio || '未填写'}}</text></view>
    <view class="info-row"><text class="muted">角色</text><text class="tag tag-primary">{{roleLabel}}</text></view>
    <view class="info-row"><text class="muted">注册时间</text><text>{{createdLabel}}</text></view>
  </view>

  <view class="card" wx:if="{{editing}}">
    <view class="avatar-edit">
      <view class="avatar-edit-preview">
        <user-avatar wx:if="{{!avatarPreview}}" displayName="{{form.displayName || user.displayName}}" seed="{{user.id}}" size="160" />
        <image wx:else class="avatar-edit-image" src="{{avatarPreview}}" mode="aspectFill" />
      </view>
      <view class="avatar-edit-actions">
        <button size="mini" type="primary" bindtap="chooseAvatar">选择图片</button>
        <button size="mini" class="btn-plain" bindtap="resetAvatar">恢复默认</button>
      </view>
      <text class="hint">支持 JPG / PNG / WebP，不超过 2MB</text>
    </view>
    <view class="form-item">
      <view class="form-label">姓名</view>
      <input class="form-input" data-field="displayName" value="{{form.displayName}}" bindinput="onInput" placeholder-class="form-placeholder" />
    </view>
    <view class="form-item">
      <view class="form-label">手机</view>
      <input class="form-input" data-field="phone" value="{{form.phone}}" bindinput="onInput" placeholder="选填" placeholder-class="form-placeholder" />
    </view>
    <view class="form-item">
      <view class="form-label">简介</view>
      <input class="form-input" data-field="bio" value="{{form.bio}}" bindinput="onInput" maxlength="80" placeholder="最多 80 字" placeholder-class="form-placeholder" />
    </view>
    <text class="hint">{{form.bio ? form.bio.length : 0}}/80</text>
    <button class="save-btn" type="primary" bindtap="saveProfile">保存</button>
  </view>

  <view class="card quick-entry" bindtap="goNotifications">
    <view class="flex-between">
      <text>消息中心</text>
      <text wx:if="{{unreadNotifications}}" class="tag tag-danger">{{unreadNotifications}} 条未读</text>
      <text wx:else class="muted">暂无未读</text>
    </view>
  </view>

  <view class="card">
    <view class="menu-link" wx:for="{{profileMenu}}" wx:key="path" bindtap="go" data-url="{{item.path}}">
      <text>{{item.label}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="logout">退出登录</button>
</view>
