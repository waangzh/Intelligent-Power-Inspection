<view class="container">
  <page-header title="实时监控" description="机器人 GPS 位置、巡检路线与 Bridge 遥测（数据来自后端 API）" />

  <view wx:if="{{loadError}}" class="empty-hint card">{{loadError}}</view>

  <view class="card">
    <view class="card-title map-head">
      <text>地图实时追踪 · {{selected.name || '巡检机器人'}}</text>
      <text wx:if="{{canViewTrack && trackPoints.length}}" class="track-toggle" bindtap="toggleTrack">{{showTrack ? '隐藏实际路线' : '显示实际路线'}}</text>
    </view>
    <view wx:if="{{canViewLocation}}" class="gps-meta">
      <text class="tag tag-{{locationSummary.modeLabel === '实时 GPS' ? 'success' : (locationSummary.modeLabel === 'GPS 接口未部署' ? 'warning' : 'warning')}}">{{locationSummary.modeLabel}}</text>
      <text class="gps-meta-text" wx:if="{{locationSummary.fixLabel !== '-'}}">{{locationSummary.fixLabel}}</text>
      <text class="gps-meta-text muted" wx:if="{{locationSummary.meta}}">{{locationSummary.meta}}</text>
      <text class="gps-meta-text muted" wx:if="{{routeReference && activeRoute}}">参考路线：{{activeRoute.name}}</text>
    </view>
    <map-view
      center="{{mapCenter}}"
      route="{{activeRoute}}"
      robotPosition="{{robotPos}}"
      trackPoints="{{trackPoints}}"
      showTrack="{{showTrack}}"
    />
    <view class="map-legend">
      <text class="legend-item"><text class="legend-line route" />规划路线</text>
      <text class="legend-item"><text class="legend-line track" />实际路线</text>
    </view>
  </view>

  <view class="card video-card">
    <view class="card-title">模拟视频画面</view>
    <view class="video-placeholder video-placeholder-empty">
      <text class="video-hint">{{videoHint}}</text>
      <text class="video-sub" wx:if="{{selected}}">平台状态：{{selected.statusLabel}}</text>
    </view>
    <view class="video-overlay" wx:if="{{bridgeOnline && selected}}">LIVE · 前视相机 · {{selected.name}}</view>
  </view>

  <view class="card" wx:if="{{selected}}">
    <view class="card-title">遥测数据</view>
    <view class="telemetry-grid">
      <view class="telemetry-item"><text class="telemetry-value">{{selected.statusLabel}}</text><text class="telemetry-label">状态</text></view>
      <view class="telemetry-item"><text class="telemetry-value">{{selected.model}}</text><text class="telemetry-label">型号</text></view>
      <view class="telemetry-item"><text class="telemetry-value">{{selected.firmware || '-'}}</text><text class="telemetry-label">固件</text></view>
      <view class="telemetry-item"><text class="telemetry-value">{{selected.currentTaskName}}</text><text class="telemetry-label">当前任务</text></view>
    </view>
    <view class="muted">序列号 {{selected.serialNo}} · 当前任务 {{selected.currentTaskName}}</view>
  </view>

  <view class="card" wx:if="{{robots.length}}">
    <view class="card-title">机器人</view>
    <view class="robot-item {{selectedId===item.id?'active':''}}" wx:for="{{robots}}" wx:key="id" bindtap="selectRobot" data-id="{{item.id}}">
      <view class="flex-between">
        <text>{{item.name}}</text>
        <text class="tag tag-{{item.statusType}}">{{item.statusLabel}}</text>
      </view>
      <view class="muted">任务：{{item.currentTaskName}}</view>
    </view>
  </view>
</view>
