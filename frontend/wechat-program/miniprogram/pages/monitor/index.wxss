.video-card { position: relative; }
.video-placeholder { width: 100%; height: 360rpx; border-radius: 12rpx; background: #0d2137; }
.video-overlay { position: absolute; bottom: 36rpx; left: 36rpx; color: #fff; font-size: 24rpx; }
.telemetry-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 16rpx; }
.telemetry-item { flex: 1; min-width: 40%; text-align: center; padding: 16rpx; background: #f5f8fc; border-radius: 12rpx; }
.telemetry-value { display: block; font-size: 28rpx; font-weight: 600; color: #1a5fb4; }
.telemetry-label { font-size: 22rpx; color: #909399; }
.pos-hint { margin-top: 12rpx; }
.robot-scroll { max-height: 480rpx; }
.robot-item { padding: 20rpx; border-radius: 12rpx; margin-bottom: 12rpx; border: 2rpx solid #f0f2f5; }
.robot-item.active { border-color: #1a5fb4; background: #ecf5ff; }
.robot-name { font-weight: 500; }
