.video-card { position: relative; }
.video-placeholder { width: 100%; min-height: 360rpx; border-radius: 12rpx; background: var(--pi-sidebar); }
.video-placeholder-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 32rpx; box-sizing: border-box; }
.video-hint { color: var(--pi-muted); font-size: 26rpx; text-align: center; line-height: 1.5; }
.video-sub { margin-top: 12rpx; color: var(--pi-text); font-size: 24rpx; }
.video-overlay { position: absolute; bottom: 24rpx; left: 24rpx; color: #fff; font-size: 22rpx; background: rgba(7, 30, 66, 0.55); padding: 8rpx 16rpx; border-radius: 8rpx; }
.map-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.track-toggle { font-size: 24rpx; color: var(--pi-primary); flex-shrink: 0; }
.muted-inline { color: var(--pi-muted); }
.gps-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.gps-meta-text { font-size: 24rpx; }
.map-legend { display: flex; flex-wrap: wrap; gap: 20rpx; margin-top: 16rpx; }
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: var(--pi-muted); }
.legend-line { display: inline-block; width: 32rpx; height: 6rpx; border-radius: 3rpx; }
.legend-line.route { background: #1768f2; }
.legend-line.track { background: #16a34a; }
.telemetry-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 16rpx; }
.telemetry-item { flex: 1; min-width: 40%; background: var(--pi-bg); border-radius: 12rpx; padding: 16rpx; text-align: center; }
.telemetry-value { display: block; font-size: 28rpx; font-weight: 600; color: var(--pi-primary); }
.telemetry-label { font-size: 22rpx; color: var(--pi-muted-light); }
.robot-item { padding: 16rpx; border: 1rpx solid var(--pi-border); border-radius: 12rpx; margin-bottom: 12rpx; }
.robot-item.active { border-color: var(--pi-primary); background: var(--pi-primary-soft); }
