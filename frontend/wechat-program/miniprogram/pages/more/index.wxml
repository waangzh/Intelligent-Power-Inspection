<view class="container">
  <page-header title="更多功能" description="按权限展示全部功能入口" />

  <view class="card" wx:for="{{menuGroups}}" wx:key="title">
    <view class="card-title">{{item.title}}</view>
    <view class="menu-grid">
      <view class="menu-item" wx:for="{{item.items}}" wx:for-item="menu" wx:key="path" bindtap="go" data-url="{{menu.path}}">
        <text class="menu-icon">{{menu.icon}}</text>
        <text class="menu-label">{{menu.label}}</text>
        <text wx:if="{{menu.path==='/pages/notifications/index' && unreadNotifications}}" class="menu-badge">{{unreadNotifications}}</text>
      </view>
    </view>
  </view>
</view>
