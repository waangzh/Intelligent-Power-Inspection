.menu-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.menu-item { width: calc(33.33% - 12rpx); text-align: center; padding: 24rpx 8rpx; background: #f5f8fc; border-radius: 12rpx; position: relative; }
.menu-badge {
  position: absolute; top: 8rpx; right: 8rpx; min-width: 32rpx; height: 32rpx; line-height: 32rpx;
  background: #f56c6c; color: #fff; font-size: 20rpx; border-radius: 16rpx; padding: 0 8rpx;
}
.menu-icon { display: block; font-size: 40rpx; margin-bottom: 8rpx; }
.menu-label { font-size: 24rpx; color: #1a2b3c; }
