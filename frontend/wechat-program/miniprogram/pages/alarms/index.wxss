.toolbar input { border: 1rpx solid var(--pi-border); border-radius: 16rpx; padding: 16rpx; margin-bottom: 12rpx; }
.filter-row { display: flex; flex-wrap: wrap; gap: 12rpx; align-items: center; }
.filter-chip { padding: 8rpx 20rpx; background: var(--pi-bg-muted); border-radius: 12rpx; font-size: 24rpx; color: var(--pi-muted); }
.filter-chip.on { background: var(--pi-primary); color: #fff; }
.alarm-card.sel { border: 2rpx solid var(--pi-primary); }
.alarm-msg { margin: 8rpx 0; font-weight: 500; }
.alarm-img { width: 100%; height: 240rpx; border-radius: 12rpx; margin-top: 12rpx; }
.detail-row { display: flex; justify-content: space-between; padding: 8rpx 0; }
.alarm-actions { margin-top: 12rpx; display: flex; gap: 12rpx; align-items: center; flex-wrap: wrap; }
