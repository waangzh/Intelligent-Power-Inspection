.stat-item.sel { border: 2rpx solid #1a5fb4; }
.wo-title { font-weight: 600; }
.wo-desc { margin: 8rpx 0; font-size: 26rpx; color: #606266; }
.wo-actions { display: flex; gap: 12rpx; margin-top: 12rpx; }
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; z-index: 99; }
.modal-panel { width: 86%; background: #fff; border-radius: 20rpx; padding: 32rpx; max-height: 80vh; overflow-y: auto; box-sizing: border-box; }
.detail-panel .detail-row { display: flex; justify-content: space-between; gap: 16rpx; padding: 8rpx 0; align-items: flex-start; }
.detail-panel .detail-row text:last-child { text-align: right; flex: 1; }
.detail-desc-inline { color: #606266; line-height: 1.5; }
.section-title { margin: 20rpx 0 8rpx; font-size: 28rpx; font-weight: 600; color: #303133; }
.form-panel .form-item { margin-bottom: 20rpx; }
.form-label { display: block; font-size: 26rpx; color: #606266; margin-bottom: 10rpx; }
.form-item.required .form-label::before { content: '*'; color: #f56c6c; margin-right: 4rpx; }
.form-picker, .form-input { width: 100%; border: 1rpx solid #e4e9f0; border-radius: 8rpx; padding: 16rpx; box-sizing: border-box; font-size: 26rpx; color: #303133; }
.form-picker { color: #606266; }
.form-textarea { width: 100%; border: 1rpx solid #e4e9f0; border-radius: 8rpx; padding: 16rpx; min-height: 120rpx; box-sizing: border-box; font-size: 26rpx; }
.review-modes { display: flex; gap: 12rpx; }
.mode-chip { flex: 1; text-align: center; padding: 14rpx 20rpx; background: #f0f4f8; border-radius: 8rpx; font-size: 24rpx; color: #606266; }
.mode-chip.on { background: #1a5fb4; color: #fff; }
.form-actions { display: flex; gap: 16rpx; justify-content: flex-end; margin-top: 8rpx; }
