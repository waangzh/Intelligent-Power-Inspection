.scope-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  background: var(--pi-bg-muted);
  border-radius: 16rpx;
}

.scope-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--pi-muted);
  transition: background 0.2s, color 0.2s;
}

.scope-tab.active {
  background: #fff;
  color: var(--pi-primary);
  box-shadow: 0 4rpx 12rpx rgba(23, 104, 242, 0.12);
}

.scope-count {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--pi-muted-light);
}

.scope-tab.active .scope-count {
  color: var(--pi-primary);
  opacity: 0.75;
}

.status-chips {
  width: 100%;
  white-space: nowrap;
  margin: 8rpx 0 28rpx;
}

.status-chips-inner {
  display: inline-flex;
  gap: 20rpx;
  padding: 8rpx 4rpx 12rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  padding: 18rpx 28rpx;
  background: #fff;
  border: 1rpx solid var(--pi-border);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--pi-muted);
}

.chip.active {
  background: var(--pi-primary);
  border-color: var(--pi-primary);
  color: #fff;
  transform: scale(1.02);
}

.chip-count {
  font-size: 22rpx;
  opacity: 0.85;
}

.wo-card {
  padding: 28rpx 32rpx;
}

.wo-head {
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.wo-title {
  flex: 1;
  font-weight: 600;
  font-size: 30rpx;
  line-height: 1.45;
  color: var(--pi-text);
}

.wo-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.wo-meta-line {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--pi-muted);
}

.wo-desc {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--pi-border-soft);
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--pi-muted);
}

.wo-actions { display: flex; gap: 12rpx; margin-top: 20rpx; flex-wrap: wrap; }
.modal-mask { position: fixed; inset: 0; background: rgba(16, 42, 86, 0.45); display: flex; align-items: center; justify-content: center; z-index: 99; }
.modal-panel { width: 86%; background: #fff; border-radius: var(--pi-card-radius); padding: 32rpx; max-height: 80vh; overflow-y: auto; box-sizing: border-box; border: 1rpx solid var(--pi-border); box-shadow: var(--pi-card-shadow); }
.detail-panel {
  padding: 36rpx 36rpx 32rpx;
}

.detail-panel .card-title {
  margin-bottom: 8rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--pi-border-soft);
}

.detail-panel .detail-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 14rpx 0;
  line-height: 1.55;
}

.detail-panel .detail-row .muted {
  flex-shrink: 0;
  width: 152rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.detail-panel .detail-row text:last-child,
.detail-panel .detail-row .detail-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 28rpx;
  line-height: 1.55;
  color: var(--pi-text);
  word-break: normal;
  overflow-wrap: break-word;
}

.detail-panel .detail-value {
  color: var(--pi-muted);
}

.detail-panel .detail-value-strong {
  color: var(--pi-text);
}

.detail-panel .section-title {
  margin: 28rpx 0 4rpx;
  padding-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--pi-text);
  border-top: 1rpx solid var(--pi-border-soft);
}

.detail-panel .section-title:first-of-type {
  margin-top: 16rpx;
}

.detail-panel .photo-grid {
  margin: 12rpx 0 20rpx;
}

.detail-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 32rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid var(--pi-border-soft);
}
.read-only-hint {
  font-size: 24rpx;
}
.detail-actions button {
  margin: 0;
  min-width: 200rpx;
}
.form-panel .form-item { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 26rpx; color: var(--pi-muted); margin-bottom: 12rpx; }
.form-item.required .form-label::before { content: '*'; color: var(--pi-danger); margin-right: 4rpx; }
.form-picker {
  width: 100%;
  min-height: 88rpx;
  line-height: 1.5;
  border: 1rpx solid var(--pi-border);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--pi-muted);
  background: #fff;
}
.form-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--pi-border);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--pi-text);
  background: #fff;
}
.form-placeholder {
  color: var(--pi-muted-light);
  font-size: 28rpx;
}
.form-textarea {
  width: 100%;
  border: 1rpx solid var(--pi-border);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  min-height: 160rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.55;
  color: var(--pi-text);
  background: #fff;
}
.review-modes { display: flex; gap: 12rpx; }
.mode-chip { flex: 1; text-align: center; padding: 14rpx 20rpx; background: var(--pi-bg-muted); border-radius: 12rpx; font-size: 24rpx; color: var(--pi-muted); }
.mode-chip.on { background: var(--pi-primary); color: #fff; }
.form-actions { display: flex; gap: 16rpx; justify-content: flex-end; margin-top: 8rpx; }
.pending-item { padding: 16rpx 0; border-bottom: 1rpx solid var(--pi-border-soft); }
.pending-item:last-child { border-bottom: none; }
.pending-msg { margin: 8rpx 0; font-size: 26rpx; color: var(--pi-text); }
.pending-actions { margin-top: 12rpx; }
.photo-hint { display: block; font-size: 22rpx; color: var(--pi-muted-light); margin-bottom: 12rpx; }
.photo-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.photo-item { position: relative; }
.photo-thumb { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: var(--pi-bg); }
.photo-remove { position: absolute; top: -8rpx; right: -8rpx; width: 36rpx; height: 36rpx; line-height: 32rpx; text-align: center; background: var(--pi-danger); color: #fff; border-radius: 50%; font-size: 28rpx; }
.photo-add { width: 160rpx; height: 160rpx; border: 2rpx dashed var(--pi-border-strong); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 56rpx; color: var(--pi-muted-light); }
