.form-row { display: flex; align-items: center; margin-bottom: 16rpx; }
.form-label { width: 160rpx; color: var(--pi-muted); font-size: 26rpx; }
.picker-val { color: var(--pi-primary); }
.task-name { color: var(--pi-primary); font-weight: 500; }
.task-actions { display: flex; gap: 12rpx; margin-top: 12rpx; flex-wrap: wrap; }
