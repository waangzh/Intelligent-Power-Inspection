<view class="container" wx:if="{{task}}">
  <page-header title="{{task.name}}" description="任务 ID: {{task.id}}" />

  <view class="card task-card">
    <view class="task-card-head">
      <task-status-tag status="{{task.status}}" />
    </view>
    <progress class="task-progress" percent="{{task.progress}}" stroke-width="8" activeColor="#1768f2" />
    <view class="task-meta-title">基本信息</view>
    <view class="info-row"><text class="muted">路线</text><text>{{routeName}}</text></view>
    <view class="info-row"><text class="muted">机器人</text><text>{{robotName}}</text></view>
    <view class="info-row"><text class="muted">检查点</text><text>第 {{task.currentCheckpointSeq}} / {{checkpointTotal}} 个</text></view>
    <view class="info-row"><text class="muted">创建时间</text><text>{{createdLabel}}</text></view>
    <view class="info-row"><text class="muted">开始时间</text><text>{{startedLabel}}</text></view>
    <view class="task-actions">
      <button wx:if="{{canLaunch && showLaunch}}" size="mini" type="primary" bindtap="launch">{{launchLabel}}</button>
      <button wx:if="{{canControl && displayStatus==='RUNNING'}}" size="mini" bindtap="pause">暂停</button>
      <button wx:if="{{canControl && displayStatus==='PAUSED'}}" size="mini" type="primary" bindtap="resume">恢复</button>
      <button wx:if="{{canTakeover && displayStatus==='RUNNING'}}" size="mini" type="warn" bindtap="takeover">接管</button>
      <button wx:if="{{canCancel}}" size="mini" bindtap="cancel">{{cancelLabel}}</button>
    </view>
  </view>

  <view class="card" wx:if="{{route}}">
    <view class="card-title map-head">
      <text>轨迹地图</text>
      <text wx:if="{{canViewTrack && trackPoints.length}}" class="track-toggle" bindtap="toggleTrack">{{showTrack ? '隐藏实际路线' : '显示实际路线'}}</text>
    </view>
    <view wx:if="{{canViewLocation}}" class="gps-meta">
      <text class="tag tag-{{locationSummary.modeLabel === '实时 GPS' ? 'success' : 'warning'}}">{{locationSummary.modeLabel}}</text>
      <text class="gps-meta-text" wx:if="{{locationSummary.fixLabel !== '-'}}">{{locationSummary.fixLabel}}</text>
      <text class="gps-meta-text muted" wx:if="{{locationSummary.meta}}">{{locationSummary.meta}}</text>
    </view>
    <map-view
      center="{{mapCenter}}"
      route="{{route}}"
      robotPosition="{{robotPos}}"
      trackPoints="{{trackPoints}}"
      showTrack="{{showTrack}}"
    />
    <view class="map-legend">
      <text class="legend-item"><text class="legend-line route" />规划路线</text>
      <text class="legend-item"><text class="legend-line track" />实际路线</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">关联告警 ({{taskAlarms.length}})</view>
    <view class="list-item" wx:for="{{taskAlarms}}" wx:key="id">
      <text class="tag tag-warning">{{item.severity}}</text>
      <text>{{item.message}}</text>
    </view>
    <view wx:if="{{!taskAlarms.length}}" class="muted">暂无关联告警</view>
  </view>

  <view class="card">
    <view class="card-title">执行时间线</view>
    <view class="timeline">
      <view class="timeline-item" wx:for="{{events}}" wx:key="id">
        <view class="timeline-dot dot-{{item.evType}}"></view>
        <view class="timeline-body">
          <view class="timeline-time">{{item.time}} · <text class="ev-{{item.evType}}">{{item.typeLabel}}</text></view>
          <view class="timeline-msg">{{item.message}}</view>
          <view class="muted" wx:if="{{item.checkpointName}}">检查点: {{item.checkpointName}}</view>
          <image wx:if="{{item.imageUrl}}" class="event-img" src="{{item.imageUrl}}" mode="aspectFill" />
        </view>
      </view>
    </view>
    <view wx:if="{{!events.length}}" class="empty-hint">下发后将自动生成事件</view>
  </view>
</view>
<view wx:else class="empty-hint">任务不存在</view>
