.timeline { padding-left: 8rpx; }
.timeline-item { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.timeline-dot { width: 16rpx; height: 16rpx; border-radius: 50%; margin-top: 8rpx; flex-shrink: 0; background: var(--pi-primary); }
.dot-danger { background: var(--pi-danger); }
.dot-success { background: var(--pi-success); }
.dot-warning { background: var(--pi-warning); }
.dot-info { background: var(--pi-muted-light); }
.ev-danger { color: var(--pi-danger); }
.ev-success { color: var(--pi-success); }
.ev-warning { color: var(--pi-warning); }
.ev-primary { color: var(--pi-primary); }
.ev-info { color: var(--pi-muted-light); }
.timeline-body { flex: 1; }
.timeline-msg { font-size: 26rpx; }
.timeline-time { font-size: 22rpx; color: var(--pi-muted-light); }
