.task-card-head {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--pi-border-soft);
}

.task-progress {
  margin-bottom: 24rpx;
}

.task-meta-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--pi-muted);
  margin-bottom: 8rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--pi-border-soft);
}

.info-row:last-of-type {
  border-bottom: none;
}

.info-row .muted {
  flex-shrink: 0;
  min-width: 140rpx;
}

.info-row text:last-child {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: var(--pi-text);
  word-break: break-all;
}

.task-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--pi-border-soft);
}

.task-actions button {
  margin: 0;
}

.timeline { padding-left: 8rpx; }
.timeline-item { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.timeline-dot { width: 16rpx; height: 16rpx; border-radius: 50%; margin-top: 8rpx; flex-shrink: 0; background: var(--pi-primary); }
.dot-danger { background: var(--pi-danger); }
.dot-success { background: var(--pi-success); }
.dot-warning { background: var(--pi-warning); }
.dot-info { background: var(--pi-muted-light); }
.ev-danger { color: var(--pi-danger); }
.ev-success { color: var(--pi-success); }
.ev-warning { color: var(--pi-warning); }
.ev-primary { color: var(--pi-primary); }
.ev-info { color: var(--pi-muted-light); }
.timeline-body { flex: 1; }
.timeline-msg { font-size: 26rpx; line-height: 1.5; }
.timeline-time { font-size: 22rpx; color: var(--pi-muted-light); margin-bottom: 4rpx; }

.list-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  line-height: 1.5;
}

.event-img {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.map-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.track-toggle {
  font-size: 24rpx;
  color: var(--pi-primary);
  flex-shrink: 0;
}

.muted-inline {
  color: var(--pi-muted);
}

.gps-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.gps-meta-text {
  font-size: 24rpx;
}

.map-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--pi-muted);
}

.legend-line {
  display: inline-block;
  width: 32rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

.legend-line.route { background: #1768f2; }
.legend-line.track { background: #16a34a; }
