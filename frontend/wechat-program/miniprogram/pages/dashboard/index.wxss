.welcome {
  margin-bottom: 28rpx;
  padding: 32rpx 28rpx;
}

.welcome-inner {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.welcome-text {
  flex: 1;
  min-width: 0;
}

.greeting {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--pi-text);
  display: block;
  line-height: 1.4;
}

.bio {
  display: block;
  font-size: 24rpx;
  color: var(--pi-muted);
  margin-top: 10rpx;
  line-height: 1.5;
}

.stat-grid {
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  padding: 32rpx 28rpx;
  min-height: 168rpx;
  box-sizing: border-box;
}

.stat-value {
  font-size: 44rpx;
  line-height: 1.2;
}

.stat-label {
  margin-top: 14rpx;
  font-size: 26rpx;
}

.trend {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.chart-row {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 32rpx 28rpx;
}

.chart-half {
  flex: none;
  width: 100%;
  min-width: 0;
  padding: 8rpx 0 24rpx;
}

.chart-half + .chart-half {
  border-top: 1rpx solid var(--pi-border-soft);
  margin-top: 16rpx;
  padding-top: 32rpx;
  padding-bottom: 8rpx;
}

.chart-half .card-title {
  margin-bottom: 24rpx;
}

.schedule-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--pi-border-soft);
  line-height: 1.5;
}

.schedule-item:last-child {
  border-bottom: none;
  padding-bottom: 8rpx;
}

.schedule-time {
  color: var(--pi-primary);
  font-weight: 600;
  width: 108rpx;
  flex-shrink: 0;
}

.list-item {
  padding: 28rpx 0;
  line-height: 1.5;
}

.link {
  color: var(--pi-primary);
  font-size: 26rpx;
}

.card .card-title {
  margin-bottom: 20rpx;
}

.card .empty-hint {
  padding: 48rpx 24rpx;
}
