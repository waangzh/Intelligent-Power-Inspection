<view class="container">
  <view class="welcome card" wx:if="{{user}}">
    <view class="welcome-inner">
      <user-avatar displayName="{{user.displayName}}" avatarUrl="{{user.avatarUrl}}" seed="{{user.id}}" size="96" />
      <view class="welcome-text">
        <text class="greeting">{{greeting}}，{{user.displayName}}</text>
        <text class="bio">{{user.bio || '欢迎使用电力智能巡检平台'}}</text>
      </view>
    </view>
  </view>

  <page-header title="运行总览" description="电力巡检平台运行态势一屏掌握" />

  <view class="stat-grid">
    <view class="stat-item" wx:for="{{stats}}" wx:key="label">
      <view class="stat-value">{{item.value}}</view>
      <view class="stat-label">{{item.label}}</view>
      <view class="muted trend">{{item.trend}}</view>
    </view>
  </view>

  <view class="card chart-row">
    <view class="chart-half">
      <view class="card-title">告警趋势（7日）</view>
      <simple-chart type="line" data="{{alarmChartData}}" />
    </view>
    <view class="chart-half">
      <view class="card-title">任务完成率</view>
      <simple-chart type="gauge" value="{{completionRate}}" title="完成率" />
    </view>
  </view>

  <view class="card" wx:if="{{!isDispatcher && !isViewer}}">
    <view class="card-title flex-between">
      <text>今日巡检日程</text>
      <text class="link" bindtap="go" data-url="/pages/tasks/index">全部</text>
    </view>
    <view class="schedule-item" wx:for="{{schedule}}" wx:key="time">
      <text class="schedule-time">{{item.time}}</text>
      <text>{{item.text}}</text>
    </view>
    <view wx:if="{{!schedule.length}}" class="empty-hint">暂无进行中任务</view>
  </view>

  <view class="card" wx:if="{{!isDispatcher && !isViewer}}">
    <view class="card-title flex-between">
      <text>最新告警</text>
      <text class="link" bindtap="go" data-url="/pages/alarms/index">全部</text>
    </view>
    <view wx:for="{{recentAlarms}}" wx:key="id" class="list-item">
      <text class="tag tag-{{item.sevType}}">{{item.severityLabel}}</text>
      <text>{{item.message}}</text>
    </view>
    <view wx:if="{{!recentAlarms.length}}" class="empty-hint">暂无告警</view>
  </view>

</view>
