.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 48px;
  background: #ffffff;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #e4e9f0;
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding-top: 4px;
}

.tab-icon {
  width: 24px;
  height: 24px;
}

.tab-text {
  font-size: 10px;
  color: #6b7c93;
  margin-top: 2px;
}

.tab-bar-item.active .tab-text {
  color: #1a5fb4;
}

.tab-badge {
  position: absolute;
  top: 2px;
  right: 18%;
  min-width: 16px;
  height: 16px;
  line-height: 16px;
  padding: 0 4px;
  background: #f56c6c;
  color: #fff;
  font-size: 10px;
  text-align: center;
  border-radius: 8px;
  box-sizing: border-box;
}
