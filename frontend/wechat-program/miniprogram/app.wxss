@import './config/theme.wxss';

page {
  background: var(--pi-bg);
  font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--pi-text);
}

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #fff;
  border: 1rpx solid var(--pi-border);
  border-radius: var(--pi-card-radius);
  box-shadow: var(--pi-card-shadow);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: var(--pi-text);
}

.stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  min-width: 40%;
  background: #fff;
  border: 1rpx solid var(--pi-border);
  border-radius: var(--pi-card-radius);
  box-shadow: var(--pi-card-shadow);
  padding: 24rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--pi-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--pi-muted);
  margin-top: 8rpx;
}

.empty-hint {
  text-align: center;
  color: var(--pi-muted-light);
  padding: 60rpx 24rpx;
}

.btn-primary {
  background: var(--pi-primary) !important;
  color: #fff !important;
}

.btn-plain {
  background: #fff !important;
  color: var(--pi-primary) !important;
  border: 1rpx solid var(--pi-primary) !important;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-danger { background: var(--pi-danger-soft); color: var(--pi-danger); }
.tag-warning { background: var(--pi-warning-soft); color: var(--pi-warning); }
.tag-success { background: var(--pi-success-soft); color: var(--pi-success); }
.tag-info { background: var(--pi-info-soft); color: var(--pi-muted); }
.tag-primary { background: var(--pi-primary-soft); color: var(--pi-primary); }

.list-item {
  padding: 24rpx;
  border-bottom: 1rpx solid var(--pi-border-soft);
}

.list-item:last-child { border-bottom: none; }

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.muted { color: var(--pi-muted-light); font-size: 24rpx; }

.link { color: var(--pi-primary); font-size: 26rpx; }
