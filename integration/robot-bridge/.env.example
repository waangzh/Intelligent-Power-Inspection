PLATFORM_BASE_URL=http://127.0.0.1:8080
PLATFORM_BEARER_TOKEN=token-placeholder
ROBOT_AUTH_TOKENS_JSON={"robot-001":"token-placeholder"}
ROBOT_BRIDGE_STORAGE_PATH=/var/lib/robot-bridge/robot-bridge.db
BRIDGE_API_TOKEN=token-placeholder
BRIDGE_MAP_UPLOAD_ENABLED=false
BRIDGE_MAP_UPLOAD_CONNECT_TIMEOUT_SEC=10
BRIDGE_MAP_UPLOAD_READ_TIMEOUT_SEC=60
BRIDGE_MAP_UPLOAD_YAML_MAX_BYTES=1048576
BRIDGE_MAP_UPLOAD_PGM_MAX_BYTES=104857600
BRIDGE_MAP_UPLOAD_REQUEST_MAX_BYTES=115343360
BRIDGE_MAP_UPLOAD_TEMP_DIR=/var/lib/robot-bridge/map-upload-tmp
BRIDGE_INSPECTION_IMAGE_UPLOAD_ENABLED=false
BRIDGE_INSPECTION_IMAGE_UPLOAD_MAX_BYTES=20971520
BRIDGE_INSPECTION_IMAGE_UPLOAD_TEMP_DIR=/var/lib/robot-bridge/inspection-image-upload-tmp
